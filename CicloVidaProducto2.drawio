        </mxCell>
        <mxCell id="o3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#16a34a;fillColor=#dcfce7;fontColor=#14532d;fontSize=12;align=center;verticalAlign=middle;spacing=7;arcSize=10;" value="&lt;b&gt;7. Revisar respuesta del proveedor&lt;/b&gt;&lt;br&gt;Detectar cambios de precio, cantidades, sustituciones, mínimos, backorders o productos eliminados." vertex="1">
