          <mxGeometry x="1020" y="120" width="270" height="1850" as="geometry"/>
        </mxCell>
        <mxCell id="n8" value="SHOPIFY / VENTAS / POSVENTA" style="swimlane;horizontal=0;startSize=28;rounded=0;html=1;fontSize=12;fontStyle=1;align=center;verticalAlign=top;fillColor=#ffffff;swimlaneFillColor=#fafafa;strokeColor=#cbd5e1;strokeWidth=1;fillColor=#e9f7f2;swimlaneFillColor=#e9f7f2;" parent="1" vertex="1">
          <mxGeometry x="1300" y="120" width="280" height="1850" as="geometry"/>
        </mxCell>
        <mxCell id="n9" value="&lt;b&gt;Seleccionar producto y cantidad&lt;/b&gt;&lt;br&gt;Catálogo, carrito del proveedor o trade show." style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fontSize=12;align=center;verticalAlign=middle;fillColor=#eaf2ff;strokeColor=#4f81bd;strokeWidth=1.5;spacing=6;" parent="1" vertex="1">
          <mxGeometry x="45" y="180" width="170" height="78" as="geometry"/>
        </mxCell>
        <mxCell id="n10" value="&lt;b&gt;D001&lt;/b&gt;&lt;br&gt;Product Selection Form" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;fontSize=10;align=center;verticalAlign=middle;fillColor=#ffffff;strokeColor=#7f8c8d;strokeWidth=1;spacing=4;" parent="1" vertex="1">
          <mxGeometry x="48" y="275" width="165" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="n11" value="&lt;b&gt;Preparar solicitud al proveedor&lt;/b&gt;&lt;br&gt;Solicitar PO, información y lista de precios." style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fontSize=12;align=center;verticalAlign=middle;fillColor=#eaf2ff;strokeColor=#4f81bd;strokeWidth=1.5;spacing=6;" parent="1" vertex="1">
          <mxGeometry x="270" y="380" width="190" height="82" as="geometry"/>
        </mxCell>
        <mxCell id="n12" value="&lt;b&gt;D004&lt;/b&gt;&lt;br&gt;PO Request to Supplier" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;fontSize=10;align=center;verticalAlign=middle;fillColor=#ffffff;strokeColor=#7f8c8d;strokeWidth=1;spacing=4;" parent="1" vertex="1">
          <mxGeometry x="275" y="480" width="180" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="n13" value="&lt;b&gt;Crear PO en la app&lt;/b&gt;&lt;br&gt;Supplier · PO Number · Landed Base · fecha · notas." style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fontSize=12;align=center;verticalAlign=middle;fillColor=#f1ecff;strokeColor=#8064a2;strokeWidth=1.5;spacing=6;" parent="1" vertex="1">
          <mxGeometry x="525" y="580" width="190" height="88" as="geometry"/>
        </mxCell>
        <mxCell id="n14" value="&lt;b&gt;Registro:&lt;/b&gt;&lt;br&gt;&lt;code&gt;master_purchase_orders&lt;/code&gt;&lt;br&gt;Estado inicial: &lt;code&gt;draft&lt;/code&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fontSize=11;align=center;verticalAlign=middle;fillColor=#f2f2f2;strokeColor=#7f8c8d;strokeWidth=1.2;spacing=5;" parent="1" vertex="1">
          <mxGeometry x="535" y="690" width="170" height="72" as="geometry"/>
        </mxCell>
        <mxCell id="n15" value="&lt;b&gt;Elegir fuente de entrada del ítem&lt;/b&gt;&lt;br&gt;Manual · Excel · CSV · PDF/OCR · scraper." style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fontSize=12;align=center;verticalAlign=middle;fillColor=#f1ecff;strokeColor=#8064a2;strokeWidth=1.5;spacing=6;" parent="1" vertex="1">
          <mxGeometry x="525" y="800" width="190" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="n16" value="&lt;b&gt;¿Item Number ya existe?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;fillColor=#fffbe6;strokeColor=#b59b00;strokeWidth=1.5;spacing=4;" parent="1" vertex="1">
          <mxGeometry x="545" y="930" width="150" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="n17" value="&lt;b&gt;Reutilizar producto maestro&lt;/b&gt;&lt;br&gt;Cargar datos existentes y conservar historial." style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fontSize=12;align=center;verticalAlign=middle;fillColor=#f1ecff;strokeColor=#8064a2;strokeWidth=1.5;spacing=6;" parent="1" vertex="1">
          <mxGeometry x="520" y="1090" width="200" height="82" as="geometry"/>
        </mxCell>
        <mxCell id="n18" value="&lt;b&gt;Crear producto provisional&lt;/b&gt;&lt;br&gt;Marcar origen como producto nuevo." style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fontSize=12;align=center;verticalAlign=middle;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=1.5;spacing=6;" parent="1" vertex="1">
          <mxGeometry x="790" y="1090" width="200" height="82" as="geometry"/>
        </mxCell>
        <mxCell id="n19" value="&lt;b&gt;Clasificación en cascada&lt;/b&gt;&lt;br&gt;Supplier → Category → Description → SubCategory" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fontSize=12;align=center;verticalAlign=middle;fillColor=#f1ecff;strokeColor=#8064a2;strokeWidth=1.5;spacing=6;" parent="1" vertex="1">
          <mxGeometry x="525" y="1230" width="205" height="92" as="geometry"/>
        </mxCell>
        <mxCell id="n20" value="&lt;b&gt;Automatizaciones por Description&lt;/b&gt;&lt;br&gt;FacturaTica · campos dinámicos · subcategorías válidas · obligatorios." style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fontSize=12;align=center;verticalAlign=middle;fillColor=#f1ecff;strokeColor=#8064a2;strokeWidth=1.5;spacing=6;" parent="1" vertex="1">
          <mxGeometry x="525" y="1360" width="205" height="104" as="geometry"/>
        </mxCell>
        <mxCell id="n21" value="&lt;b&gt;Completar identidad del producto&lt;/b&gt;&lt;br&gt;ES/EN · UPC · materiales · medidas · color · colección · diseño · origen · marca · construcción · imágenes." style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fontSize=12;align=center;verticalAlign=middle;fillColor=#f1ecff;strokeColor=#8064a2;strokeWidth=1.5;spacing=6;" parent="1" vertex="1">
          <mxGeometry x="525" y="1500" width="205" height="125" as="geometry"/>
        </mxCell>
        <mxCell id="n22" value="&lt;b&gt;Crear / actualizar línea de PO&lt;/b&gt;&lt;br&gt;&lt;code&gt;master_po_lines&lt;/code&gt;&lt;br&gt;WC · FC · Special Cost · descuento · UoM · pack qty · order/invoiced/shipped qty · invoice." style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fontSize=12;align=center;verticalAlign=middle;fillColor=#f1ecff;strokeColor=#8064a2;strokeWidth=1.5;spacing=6;" parent="1" vertex="1">
          <mxGeometry x="525" y="1665" width="205" height="145" as="geometry"/>
        </mxCell>
        <mxCell id="n23" value="&lt;b&gt;Validar antes de continuar&lt;/b&gt;&lt;br&gt;Item único · UPC como advertencia · costos · cantidades · campos requeridos · clasificación completa." style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fontSize=12;align=center;verticalAlign=middle;fillColor=#f1ecff;strokeColor=#8064a2;strokeWidth=1.5;spacing=6;" parent="1" vertex="1">
          <mxGeometry x="525" y="1850" width="205" height="105" as="geometry"/>
        </mxCell>
        <mxCell id="n24" value="&lt;b&gt;Proveedor confirma recepción inicial&lt;/b&gt;&lt;br&gt;Acknowledgement / Sales Order." style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fontSize=12;align=center;verticalAlign=middle;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=1.5;spacing=6;" parent="1" vertex="1">
          <mxGeometry x="795" y="380" width="190" height="82" as="geometry"/>
        </mxCell>
        <mxCell id="n25" value="&lt;b&gt;D006&lt;/b&gt;&lt;br&gt;Supplier PO Acknowledgement" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;fontSize=10;align=center;verticalAlign=middle;fillColor=#ffffff;strokeColor=#7f8c8d;strokeWidth=1;spacing=4;" parent="1" vertex="1">
          <mxGeometry x="800" y="480" width="180" height="70" as="geometry"/>
