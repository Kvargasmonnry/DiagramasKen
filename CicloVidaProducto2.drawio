        <mxCell id="i_sync" value="&lt;b&gt;39. Consolidar maestro y stock&lt;/b&gt;&lt;br&gt;Actualizar Inventory Module con producto, cantidades, costos y referencias Windward." style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#0f766e;fillColor=#ccfbf1;fontColor=#134e4a;fontSize=12;align=center;verticalAlign=middle;spacing=7;arcSize=10;" parent="1" vertex="1">
