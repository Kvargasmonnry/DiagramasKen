        <mxCell id="d_count" value="¿Shipped = 1.er inventario&lt;br&gt;= 2.º inventario&lt;br&gt;= recepción Windward?" style="rhombus;whiteSpace=wrap;html=1;strokeColor=#a16207;fillColor=#fef3c7;fontColor=#713f12;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=5;" parent="1" vertex="1">
