        <mxCell id="g1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#2563eb;fillColor=#dbeafe;fontColor=#172554;fontSize=12;align=center;verticalAlign=middle;spacing=7;arcSize=10;" value="&lt;b&gt;1. Explorar y seleccionar&lt;/b&gt;&lt;br&gt;Catálogo, sitio del proveedor o trade show.&lt;br&gt;Elegir productos potenciales." vertex="1">
          <mxGeometry height="105" width="250" x="230" y="300" as="geometry" />
        </mxCell>
        <mxCell id="g2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#2563eb;fillColor=#dbeafe;fontColor=#172554;fontSize=12;align=center;verticalAlign=middle;spacing=7;arcSize=10;" value="&lt;b&gt;2. Armar carrito del proveedor&lt;/b&gt;&lt;br&gt;Agregar SKU/variante, color, tamaño y cantidad.&lt;br&gt;Conservar enlace o captura del carrito." vertex="1">
          <mxGeometry height="120" width="300" x="520" y="300" as="geometry" />
        </mxCell>
        <mxCell id="g3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#2563eb;fillColor=#dbeafe;fontColor=#172554;fontSize=12;align=center;verticalAlign=middle;spacing=7;arcSize=10;" value="&lt;b&gt;3. Revisar carrito&lt;/b&gt;&lt;br&gt;Duplicados · sets completos · piezas · cantidades · disponibilidad visible · productos para tienda o pedido especial." vertex="1">
          <mxGeometry height="130" width="330" x="860" y="295" as="geometry" />
        </mxCell>
        <mxCell id="o1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#16a34a;fillColor=#dcfce7;fontColor=#14532d;fontSize=12;align=center;verticalAlign=middle;spacing=7;arcSize=10;" value="&lt;b&gt;4. Recibir carrito/lista de Gerencia&lt;/b&gt;&lt;br&gt;Convertir la selección en &lt;b&gt;D001 Product Selection Form&lt;/b&gt; y ordenar la información por proveedor.&lt;div&gt;&lt;table&gt;&lt;tbody&gt;&lt;tr data-start=&quot;1171&quot; data-end=&quot;1396&quot;&gt;&lt;td data-col-size=&quot;xl&quot; data-start=&quot;1207&quot; data-end=&quot;1396&quot;&gt;Formulario donde se registra la selección inicial de Gerencia: productos, códigos, variantes, acabados, tamaños y cantidades elegidas desde catálogo, carrito del proveedor o trade show.&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;table&gt;&lt;tbody&gt;&lt;tr data-start=&quot;1397&quot; data-end=&quot;1542&quot;&gt;&lt;td data-start=&quot;1397&quot; data-end=&quot;1408&quot; data-col-size=&quot;sm&quot;&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="125" width="330" x="860" y="490" as="geometry" />
        </mxCell>
        <mxCell id="o2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#16a34a;fillColor=#dcfce7;fontColor=#14532d;fontSize=12;align=center;verticalAlign=middle;spacing=7;arcSize=10;" value="&lt;b&gt;5. Solicitar PO e información&lt;/b&gt;&lt;br&gt;Enviar &lt;b&gt;D004 PO Request to Supplier&lt;/b&gt;.&lt;br&gt;Solicitar info para confirmar artículos, precios, cantidades, disponibilidad y datos del producto." vertex="1">
          <mxGeometry height="115" width="330" x="860" y="700" as="geometry" />
        </mxCell>
        <mxCell id="s1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#ea580c;fillColor=#ffedd5;fontColor=#7c2d12;fontSize=12;align=center;verticalAlign=middle;spacing=7;arcSize=10;" value="&lt;b&gt;6. Responder solicitud inicial&lt;/b&gt;&lt;br&gt;Acknowledgement / Sales Order / disponibilidad inicial.&lt;br&gt;&lt;b&gt;D006 Supplier PO Acknowledgement&lt;/b&gt;.&lt;div&gt;&lt;table&gt;&lt;tbody&gt;&lt;tr data-start=&quot;1743&quot; data-end=&quot;1930&quot;&gt;&lt;td data-start=&quot;1784&quot; data-end=&quot;1930&quot; data-col-size=&quot;xl&quot;&gt;Confirmación inicial del proveedor indicando que recibió la solicitud y mostrando cómo entiende la orden. Todavía puede requerir correcciones.&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;table&gt;&lt;tbody&gt;&lt;tr data-start=&quot;1931&quot; data-end=&quot;2079&quot;&gt;&lt;td data-start=&quot;1931&quot; data-end=&quot;1942&quot; data-col-size=&quot;sm&quot;&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;/div&gt;" vertex="1">
