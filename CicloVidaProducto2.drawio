        </mxCell>
        <mxCell id="n26" value="&lt;b&gt;Marcar producto dañado&lt;/b&gt;&lt;br&gt;Tag &lt;code&gt;mch&lt;/code&gt;, precio rebajado y mensaje en Shopify." style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fontSize=12;align=center;verticalAlign=middle;fillColor=#fce4d6;strokeColor=#c55a11;strokeWidth=1.5;spacing=6;" parent="1" vertex="1">
