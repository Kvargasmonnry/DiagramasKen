        <mxCell id="g1" value="&lt;b&gt;1. Explorar y seleccionar&lt;/b&gt;&lt;br&gt;Catálogo, sitio del proveedor o trade show.&lt;br&gt;Elegir productos potenciales." style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#2563eb;fillColor=#dbeafe;fontColor=#172554;fontSize=12;align=center;verticalAlign=middle;spacing=7;arcSize=10;" parent="1" vertex="1">
          <mxGeometry x="230" y="300" width="250" height="105" as="geometry" />
        </mxCell>
        <mxCell id="g2" value="&lt;b&gt;2. Armar carrito del proveedor&lt;/b&gt;&lt;br&gt;Agregar SKU/variante, color, tamaño y cantidad.&lt;br&gt;Conservar enlace o captura del carrito." style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#2563eb;fillColor=#dbeafe;fontColor=#172554;fontSize=12;align=center;verticalAlign=middle;spacing=7;arcSize=10;" parent="1" vertex="1">
          <mxGeometry x="520" y="300" width="300" height="120" as="geometry" />
        </mxCell>
        <mxCell id="g3" value="&lt;b&gt;3. Revisar carrito&lt;/b&gt;&lt;br&gt;Duplicados · sets completos · piezas · cantidades · disponibilidad visible · productos para tienda o pedido especial." style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#2563eb;fillColor=#dbeafe;fontColor=#172554;fontSize=12;align=center;verticalAlign=middle;spacing=7;arcSize=10;" parent="1" vertex="1">
          <mxGeometry x="860" y="295" width="330" height="130" as="geometry" />
        </mxCell>
        <mxCell id="o1" value="&lt;b&gt;4. Recibir carrito/lista de Gerencia&lt;/b&gt;&lt;br&gt;Convertir la selección en &lt;b&gt;D001 Product Selection Form&lt;/b&gt; y ordenar la información por proveedor." style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#16a34a;fillColor=#dcfce7;fontColor=#14532d;fontSize=12;align=center;verticalAlign=middle;spacing=7;arcSize=10;" parent="1" vertex="1">
          <mxGeometry x="860" y="505" width="330" height="110" as="geometry" />
        </mxCell>
        <mxCell id="o2" value="&lt;b&gt;5. Solicitar PO e información&lt;/b&gt;&lt;br&gt;Enviar &lt;b&gt;D004 PO Request to Supplier&lt;/b&gt;.&lt;br&gt;Solicitar lista de precios, medidas, materiales, imágenes y condiciones." style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#16a34a;fillColor=#dcfce7;fontColor=#14532d;fontSize=12;align=center;verticalAlign=middle;spacing=7;arcSize=10;" parent="1" vertex="1">
          <mxGeometry x="860" y="635" width="330" height="115" as="geometry" />
        </mxCell>
        <mxCell id="s1" value="&lt;b&gt;6. Responder solicitud inicial&lt;/b&gt;&lt;br&gt;Acknowledgement / Sales Order / disponibilidad inicial.&lt;br&gt;&lt;b&gt;D006 Supplier PO Acknowledgement&lt;/b&gt;." style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#ea580c;fillColor=#ffedd5;fontColor=#7c2d12;fontSize=12;align=center;verticalAlign=middle;spacing=7;arcSize=10;" parent="1" vertex="1">
          <mxGeometry x="860" y="1095" width="330" height="110" as="geometry" />
        </mxCell>
        <mxCell id="o3" value="&lt;b&gt;7. Revisar respuesta del proveedor&lt;/b&gt;&lt;br&gt;Detectar cambios de precio, cantidades, sustituciones, mínimos, backorders o productos eliminados." style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#16a34a;fillColor=#dcfce7;fontColor=#14532d;fontSize=12;align=center;verticalAlign=middle;spacing=7;arcSize=10;" parent="1" vertex="1">
          <mxGeometry x="1210" y="520" width="260" height="120" as="geometry" />
        </mxCell>
        <mxCell id="e1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=1.5;strokeColor=#4b5563;fontSize=11;labelBackgroundColor=#ffffff;" parent="1" source="g1" target="g2" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=1.5;strokeColor=#4b5563;fontSize=11;labelBackgroundColor=#ffffff;" parent="1" source="g2" target="g3" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=1.5;strokeColor=#4b5563;fontSize=11;labelBackgroundColor=#ffffff;" parent="1" source="g3" target="o1" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=1.5;strokeColor=#4b5563;fontSize=11;labelBackgroundColor=#ffffff;" parent="1" source="o1" target="o2" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=1.5;strokeColor=#4b5563;fontSize=11;labelBackgroundColor=#ffffff;" parent="1" source="o2" target="s1" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=1.5;strokeColor=#4b5563;fontSize=11;labelBackgroundColor=#ffffff;" parent="1" source="s1" target="o3" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="g4" value="&lt;b&gt;8. Aprobar cambios iniciales&lt;/b&gt;&lt;br&gt;Gerencia decide cantidades, sustituciones y alcance final de la compra." style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#2563eb;fillColor=#dbeafe;fontColor=#172554;fontSize=12;align=center;verticalAlign=middle;spacing=7;arcSize=10;" parent="1" vertex="1">
          <mxGeometry x="1540" y="300" width="260" height="105" as="geometry" />
        </mxCell>
        <mxCell id="o4" value="&lt;b&gt;9. Estandarizar información&lt;/b&gt;&lt;br&gt;Preparar &lt;b&gt;D018 Standardized Product Info&lt;/b&gt; y limpiar códigos, descripciones y datos recibidos." style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#16a34a;fillColor=#dcfce7;fontColor=#14532d;fontSize=12;align=center;verticalAlign=middle;spacing=7;arcSize=10;" parent="1" vertex="1">
          <mxGeometry x="1540" y="505" width="280" height="110" as="geometry" />
        </mxCell>
        <mxCell id="o5" value="&lt;b&gt;10. Crear PO en la app&lt;/b&gt;&lt;br&gt;Supplier · PO Number · Landed Base · fecha · notas.&lt;br&gt;Estado inicial: &lt;b&gt;draft&lt;/b&gt;." style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#16a34a;fillColor=#dcfce7;fontColor=#14532d;fontSize=12;align=center;verticalAlign=middle;spacing=7;arcSize=10;" parent="1" vertex="1">
          <mxGeometry x="1850" y="505" width="280" height="110" as="geometry" />
        </mxCell>
        <mxCell id="o6" value="&lt;b&gt;11. Ingresar líneas del PO&lt;/b&gt;&lt;br&gt;Manual · Excel · CSV · PDF/OCR · scraper por código del proveedor." style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#16a34a;fillColor=#dcfce7;fontColor=#14532d;fontSize=12;align=center;verticalAlign=middle;spacing=7;arcSize=10;" parent="1" vertex="1">
          <mxGeometry x="2160" y="505" width="280" height="105" as="geometry" />
        </mxCell>
        <mxCell id="d_exist" value="¿Item Number&lt;br&gt;ya existe?" style="rhombus;whiteSpace=wrap;html=1;strokeColor=#a16207;fillColor=#fef3c7;fontColor=#713f12;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=5;" parent="1" vertex="1">
          <mxGeometry x="2185" y="830" width="125" height="100" as="geometry" />
        </mxCell>
        <mxCell id="i_exist" value="&lt;b&gt;Reutilizar producto maestro&lt;/b&gt;&lt;br&gt;Cargar identidad e historial existente." style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#0f766e;fillColor=#ccfbf1;fontColor=#134e4a;fontSize=12;align=center;verticalAlign=middle;spacing=7;arcSize=10;" parent="1" vertex="1">
          <mxGeometry x="2350" y="785" width="220" height="90" as="geometry" />
        </mxCell>
        <mxCell id="i_new" value="&lt;b&gt;Crear producto provisional&lt;/b&gt;&lt;br&gt;Marcar origen = nuevo y completar identidad." style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#0f766e;fillColor=#ccfbf1;fontColor=#134e4a;fontSize=12;align=center;verticalAlign=middle;spacing=7;arcSize=10;" parent="1" vertex="1">
          <mxGeometry x="2350" y="920" width="220" height="95" as="geometry" />
        </mxCell>
        <mxCell id="i_class" value="&lt;b&gt;12. Clasificar y enriquecer&lt;/b&gt;&lt;br&gt;Supplier → Category → Description → SubCategory.&lt;br&gt;FacturaTica, campos dinámicos, materiales, medidas, color, marca, imágenes." style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#0f766e;fillColor=#ccfbf1;fontColor=#134e4a;fontSize=12;align=center;verticalAlign=middle;spacing=7;arcSize=10;" parent="1" vertex="1">
