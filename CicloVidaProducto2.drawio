        <mxCell id="note_model" value="&lt;b&gt;Modelo de datos&lt;/b&gt;&lt;br&gt;Producto maestro = identidad persistente.&lt;br&gt;Línea de PO = una compra específica.&lt;br&gt;Unidad física = pieza que se mueve, vende, devuelve o da de baja." style="shape=note;whiteSpace=wrap;html=1;strokeColor=#64748b;fillColor=#fff7ed;fontColor=#7c2d12;fontSize=11;align=left;verticalAlign=top;spacing=8;size=15;" parent="1" vertex="1">
