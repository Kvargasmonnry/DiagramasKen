        <mxCell id="b6" value="&lt;b&gt;37. Segundo inventario&lt;/b&gt;&lt;br&gt;Recontar después de recepción, etiquetado y acomodo." style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#0f766e;fillColor=#ccfbf1;fontColor=#134e4a;fontSize=12;align=center;verticalAlign=middle;spacing=7;arcSize=10;" parent="1" vertex="1">
