          <mxGeometry x="65" y="1410" width="440" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="v56" value="&lt;b&gt;Fuente de verdad por etapa&lt;/b&gt;&lt;br&gt;Inventory Module: creación y preparación.&lt;br&gt;Windward: inventario y movimientos.&lt;br&gt;Shopify: publicación ecommerce." style="shape=note;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacing=8;strokeWidth=1.1;fillColor=#FFFBEA;strokeColor=#C9B458;" parent="1" vertex="1">
          <mxGeometry x="535" y="1410" width="410" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="v57" value="&lt;b&gt;Incoming&lt;/b&gt;&lt;br&gt;No es otro producto. Es la misma línea de PO mientras la mercancía está pendiente, en tránsito o aún no recibida." style="shape=note;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacing=8;strokeWidth=1.1;fillColor=#FFFBEA;strokeColor=#C9B458;" parent="1" vertex="1">
          <mxGeometry x="975" y="1410" width="390" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="v58" value="&lt;b&gt;Fin de vida&lt;/b&gt;&lt;br&gt;La unidad física puede terminar por venta, devolución definitiva, daño, donación o desecho. El producto maestro solo se inactiva cuando no queda stock ni futura demanda." style="shape=note;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacing=8;strokeWidth=1.1;fillColor=#FFFBEA;strokeColor=#C9B458;" parent="1" vertex="1">
          <mxGeometry x="1395" y="1410" width="520" height="120" as="geometry"/>
        </mxCell>
