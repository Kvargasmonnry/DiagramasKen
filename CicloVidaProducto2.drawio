        <mxCell id="n16" value="&lt;b&gt;Registrar movimiento de stock&lt;/b&gt;&lt;br&gt;Windward descuenta o reclasifica; Shopify recibe actualización." style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fontSize=12;align=center;verticalAlign=middle;fillColor=#e2f0d9;strokeColor=#70ad47;strokeWidth=1.5;spacing=6;" parent="1" vertex="1">
