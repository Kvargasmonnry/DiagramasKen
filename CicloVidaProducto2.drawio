        </mxCell>
        <mxCell id="note_incoming" value="&lt;b&gt;Incoming&lt;/b&gt;&lt;br&gt;No es otro producto. Es una vista derivada de líneas pertenecientes a POs abiertos/borrador con cantidades pendientes de recibir." style="shape=note;whiteSpace=wrap;html=1;strokeColor=#64748b;fillColor=#fff7ed;fontColor=#7c2d12;fontSize=11;align=left;verticalAlign=top;spacing=8;size=15;" parent="1" vertex="1">
