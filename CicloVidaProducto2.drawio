        <mxCell id="n24" value="&lt;b&gt;Gestionar RMA / garantía / repuesto&lt;/b&gt;&lt;br&gt;Proveedor puede emitir pieza, reemplazo o crédito." style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fontSize=12;align=center;verticalAlign=middle;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=1.5;spacing=6;" parent="1" vertex="1">
