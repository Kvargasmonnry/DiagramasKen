<?xml version='1.0' encoding='utf-8'?>
<mxfile host="app.diagrams.net" agent="ChatGPT" version="26.0.11">
  <diagram id="exec-view" name="00 - Vista ejecutiva">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="n1" value="CICLO DE VIDA DE UN PRODUCTO EN MONNRY" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=26;fontStyle=1;fontColor=#17365d;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="250" y="20" width="1100" height="44" as="geometry"/>
        </mxCell>
        <mxCell id="n2" value="Vista ejecutiva. Cada fase se desarrolla en las páginas siguientes; el protagonista es un SKU/producto específico." style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#5b6573;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="180" y="66" width="1240" height="34" as="geometry"/>
        </mxCell>
        <mxCell id="n3" value="&lt;b&gt;1. Selección y alta&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Gerencia selecciona el producto. La app decide si reutiliza un producto maestro o crea uno nuevo.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=16;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;strokeWidth=2;shadow=0;fillColor=#eaf2ff;strokeColor=#4f81bd;" parent="1" vertex="1">
          <mxGeometry x="60" y="160" width="250" height="115" as="geometry"/>
        </mxCell>
        <mxCell id="n4" value="&lt;b&gt;2. PO y confirmación&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;El producto se convierte en una línea de PO: costos, cantidades, documentos y aprobación.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=16;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;strokeWidth=2;shadow=0;fillColor=#f1ecff;strokeColor=#8064a2;" parent="1" vertex="1">
          <mxGeometry x="340" y="160" width="250" height="115" as="geometry"/>
        </mxCell>
        <mxCell id="n5" value="&lt;b&gt;3. ATS, factura y envío&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Se confirma disponibilidad, pago, facturación, manifiesto y mercancía efectivamente enviada.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=16;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;strokeWidth=2;shadow=0;fillColor=#fff2cc;strokeColor=#d6b656;" parent="1" vertex="1">
          <mxGeometry x="620" y="160" width="250" height="115" as="geometry"/>
        </mxCell>
        <mxCell id="n6" value="&lt;b&gt;4. Importación y recepción&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Recepción USA, importación, gastos, primer inventario, recepción en Windward y segundo inventario.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=16;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;strokeWidth=2;shadow=0;fillColor=#e2f0d9;strokeColor=#70ad47;" parent="1" vertex="1">
          <mxGeometry x="900" y="160" width="250" height="115" as="geometry"/>
        </mxCell>
        <mxCell id="n7" value="&lt;b&gt;5. Activación comercial&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Precio, etiquetas, ubicación, stock operativo, Shopify, imágenes, tags, familias y tamaños.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=16;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;strokeWidth=2;shadow=0;fillColor=#d9ead3;strokeColor=#38761d;" parent="1" vertex="1">
          <mxGeometry x="1180" y="160" width="250" height="115" as="geometry"/>
        </mxCell>
        <mxCell id="e8" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=1.4;strokeColor=#64748b;fontSize=10;labelBackgroundColor=#ffffff;" parent="1" source="n3" target="n4" edge="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e9" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=1.4;strokeColor=#64748b;fontSize=10;labelBackgroundColor=#ffffff;" parent="1" source="n4" target="n5" edge="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e10" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=1.4;strokeColor=#64748b;fontSize=10;labelBackgroundColor=#ffffff;" parent="1" source="n5" target="n6" edge="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e11" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=1.4;strokeColor=#64748b;fontSize=10;labelBackgroundColor=#ffffff;" parent="1" source="n6" target="n7" edge="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="n12" value="&lt;b&gt;6. Operación e inventario&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Exhibición, bodega, reservas, conteos periódicos, ajustes y sincronización de stock.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=16;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;strokeWidth=2;shadow=0;fillColor=#e2f0d9;strokeColor=#70ad47;" parent="1" vertex="1">
          <mxGeometry x="1180" y="390" width="250" height="115" as="geometry"/>
        </mxCell>
        <mxCell id="n13" value="&lt;b&gt;7. Venta y entrega&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Venta POS/Shopify, pick slip, retiro o transporte, descuento de inventario.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=16;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;strokeWidth=2;shadow=0;fillColor=#d9ead3;strokeColor=#38761d;" parent="1" vertex="1">
          <mxGeometry x="900" y="390" width="250" height="115" as="geometry"/>
        </mxCell>
        <mxCell id="n14" value="&lt;b&gt;8. Posventa o cierre&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Devolución, garantía, reparación, RMA, rebaja por daño, reintegro o baja definitiva.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=16;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;strokeWidth=2;shadow=0;fillColor=#fce4d6;strokeColor=#c55a11;" parent="1" vertex="1">
          <mxGeometry x="620" y="390" width="250" height="115" as="geometry"/>
        </mxCell>
        <mxCell id="n15" value="&lt;b&gt;9. Reposición&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;El producto maestro permanece y puede volver a participar en un nuevo PO.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=16;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;strokeWidth=2;shadow=0;fillColor=#eaf2ff;strokeColor=#4f81bd;" parent="1" vertex="1">
          <mxGeometry x="340" y="390" width="250" height="115" as="geometry"/>
        </mxCell>
        <mxCell id="e16" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=1.4;strokeColor=#64748b;fontSize=10;labelBackgroundColor=#ffffff;" parent="1" source="n7" target="n12" edge="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e17" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=1.4;strokeColor=#64748b;fontSize=10;labelBackgroundColor=#ffffff;" parent="1" source="n12" target="n13" edge="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e18" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=1.4;strokeColor=#64748b;fontSize=10;labelBackgroundColor=#ffffff;" parent="1" source="n13" target="n14" edge="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e19" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=1.4;strokeColor=#64748b;fontSize=10;labelBackgroundColor=#ffffff;" parent="1" source="n14" target="n15" edge="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e20" value="Nuevo PO" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=0;strokeWidth=1.2;strokeColor=#94a3b8;dashed=1;fontSize=10;labelBackgroundColor=#ffffff;" parent="1" source="n15" target="n4" edge="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="280" y="448"/>
              <mxPoint x="280" y="300"/>
              <mxPoint x="465" y="300"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="n21" value="&lt;b&gt;PRODUCTO MAESTRO&lt;/b&gt;&lt;br&gt;Identidad persistente: item number, proveedor, descripción, atributos, categoría, imágenes, Shopify y Windward." style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fontSize=12;align=center;verticalAlign=middle;fillColor=#eaf2ff;strokeColor=#4f81bd;strokeWidth=1.5;spacing=6;" parent="1" vertex="1">
          <mxGeometry x="100" y="660" width="400" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="n22" value="&lt;b&gt;LÍNEA DE PO&lt;/b&gt;&lt;br&gt;Compra específica: costos, cantidades, factura, shipped, landed cost, primer y segundo inventario." style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fontSize=12;align=center;verticalAlign=middle;fillColor=#f1ecff;strokeColor=#8064a2;strokeWidth=1.5;spacing=6;" parent="1" vertex="1">
          <mxGeometry x="600" y="660" width="400" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="n23" value="&lt;b&gt;UNIDAD FÍSICA&lt;/b&gt;&lt;br&gt;La pieza real: en tránsito, recibida, ubicada, disponible, reservada, vendida, devuelta, reparada o dada de baja." style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fontSize=12;align=center;verticalAlign=middle;fillColor=#e2f0d9;strokeColor=#70ad47;strokeWidth=1.5;spacing=6;" parent="1" vertex="1">
          <mxGeometry x="1100" y="660" width="400" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="n24" value="&lt;b&gt;Principio del diagrama:&lt;/b&gt; el producto maestro no “muere” cuando se vende una unidad. Puede mantener historial, volver a comprarse, cambiar precio, recibir nuevas imágenes o quedar inactivo." style="shape=note;whiteSpace=wrap;html=1;size=18;fontSize=10;align=left;verticalAlign=top;fillColor=#fffdf0;strokeColor=#c9b458;spacing=6;" parent="1" vertex="1">
          <mxGeometry x="190" y="880" width="1220" height="90" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="selection-po" name="01 - Selección, alta y PO">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="2050" math="0" shadow="0">
      <root>
