          <mxGeometry x="250" y="20" width="1100" height="44" as="geometry"/>
        </mxCell>
        <mxCell id="n2" value="Detalle desde la selección comercial hasta que el producto queda validado como línea de una orden de compra." style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#5b6573;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="180" y="66" width="1240" height="34" as="geometry"/>
        </mxCell>
        <mxCell id="n3" value="GERENCIA" style="swimlane;horizontal=0;startSize=28;rounded=0;html=1;fontSize=12;fontStyle=1;align=center;verticalAlign=top;fillColor=#ffffff;swimlaneFillColor=#fafafa;strokeColor=#cbd5e1;strokeWidth=1;fillColor=#eef5ff;swimlaneFillColor=#eef5ff;" parent="1" vertex="1">
          <mxGeometry x="20" y="120" width="220" height="1850" as="geometry"/>
