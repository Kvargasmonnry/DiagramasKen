        </mxCell>
        <mxCell id="b7" value="&lt;b&gt;38. Ubicar y liberar&lt;/b&gt;&lt;br&gt;Piso · bodega · reservado/special order.&lt;br&gt;La unidad queda operativa." style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#0f766e;fillColor=#ccfbf1;fontColor=#134e4a;fontSize=12;align=center;verticalAlign=middle;spacing=7;arcSize=10;" parent="1" vertex="1">
