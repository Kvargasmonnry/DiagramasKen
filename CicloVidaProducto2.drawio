        <mxCell id="n31" value="&lt;b&gt;Special Order&lt;/b&gt;&lt;br&gt;La unidad puede llegar ya asignada a un cliente; se separa desde recepción y no entra al stock libre de piso." style="shape=note;whiteSpace=wrap;html=1;size=18;fontSize=10;align=left;verticalAlign=top;fillColor=#fffdf0;strokeColor=#c9b458;spacing=6;" parent="1" vertex="1">
