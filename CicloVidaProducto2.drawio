        <mxCell id="note_truth" value="&lt;b&gt;Fuentes de verdad&lt;/b&gt;&lt;br&gt;Inventory Module: creación, clasificación y preparación.&lt;br&gt;Windward: stock, ubicación y movimientos.&lt;br&gt;Shopify: proyección ecommerce." style="shape=note;whiteSpace=wrap;html=1;strokeColor=#64748b;fillColor=#fff7ed;fontColor=#7c2d12;fontSize=11;align=left;verticalAlign=top;spacing=8;size=15;" parent="1" vertex="1">
